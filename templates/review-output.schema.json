{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review Output Schema",
  "type": "object",
  "description": "Schema for Shokunin Review output",
  "required": ["verdict", "score", "confidence", "findings"],
  "properties": {
    "verdict": {
      "type": "object",
      "required": ["emoji", "text", "band"],
      "properties": {
        "emoji": { "type": "string", "enum": ["🟢", "🟡", "🟠", "🔴", "⛔"] },
        "text": { "type": "string" },
        "band": { "type": "string", "enum": ["Review-ready", "Ready with minor fixes", "Needs major fixes", "Needs revision", "Not review-ready"] }
      }
    },
    "score": {
      "type": "object",
      "required": ["total", "confidence"],
      "properties": {
        "total": { "type": "integer", "minimum": 0, "maximum": 100 },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "dimension_breakdown": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0, "maximum": 100 }
        },
        "score_caps_applied": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["cap", "max_score"],
            "properties": {
              "cap": { "type": "string" },
              "max_score": { "type": "integer", "minimum": 0, "maximum": 100 }
            }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "validator", "tag", "severity", "issue", "recommended_fix"],
        "properties": {
          "id": { "type": "string" },
          "validator": { "type": "string" },
          "tag": { "type": "string" },
          "severity": { "type": "string", "enum": ["blocker", "high", "medium", "low"] },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "category": { "type": "string" },
          "location": { "type": "string" },
          "issue": { "type": "string" },
          "evidence_from_artifact": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "recommended_fix": { "type": "string" },
          "example_fix": { "type": "string" },
          "acceptance_test": { "type": "string" },
          "needs_human_judgment": { "type": "boolean" }
        }
      }
    },
    "recommended_action": {
      "type": "string"
    },
    "suggested_command": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "missing_context": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "artifact_type": { "type": "string" },
        "classification_confidence": { "type": "string" },
        "review_mode": { "type": "string" },
        "duration_seconds": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  }
}
