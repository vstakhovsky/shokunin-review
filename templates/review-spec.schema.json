{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review Spec Schema",
  "type": "object",
  "description": "Schema for review specification",
  "required": ["artifact_type", "review_mode"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": ["PRD", "RFC", "EXPERIMENT_PLAN", "PRODUCT_STRATEGY", "UNKNOWN"],
      "description": "Type of artifact being reviewed"
    },
    "detected_maturity": {
      "type": "string",
      "enum": ["draft", "proposal", "ready_for_review", "unknown"],
      "description": "Detected maturity level of artifact"
    },
    "audience": {
      "type": "string",
      "enum": ["internal", "external", "technical", "executive", "mixed"],
      "description": "Primary audience for artifact"
    },
    "review_mode": {
      "type": "string",
      "enum": ["fast", "deep", "draft"],
      "description": "Review mode"
    },
    "expected_state": {
      "type": "string",
      "description": "Expected state of artifact"
    },
    "selected_dimensions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Scoring dimensions to apply"
    },
    "validator_budget": {
      "type": "integer",
      "description": "Maximum number of validators to run (null = no limit)"
    },
    "finding_budget": {
      "type": "integer",
      "description": "Maximum findings to output (default: 5)"
    },
    "score_cap_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cap", "max_score"],
        "properties": {
          "cap": { "type": "string" },
          "max_score": { "type": "integer" }
        }
      },
      "description": "Applicable score cap rules"
    },
    "classification_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Confidence in artifact classification"
    }
  }
}
